modules = ["php-8.2", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_ENV = "dev"
APP_SECRET = "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6"
MESSENGER_TRANSPORT_DSN = "doctrine://default"
MAILER_DSN = "null://null"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && php -S 0.0.0.0:5000 -t public public/router.php"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["php", "-S", "0.0.0.0:5000", "-t", "public", "public/router.php"]
build = ["bash", "-c", "cd /home/runner/workspace && composer install --no-dev --optimize-autoloader && yarn install && yarn build"]
